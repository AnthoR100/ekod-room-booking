meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/auth/register
  body: json
  auth: none
}

body:json {
  {
    "firstName": "Zaki",
    "lastName": "Sal",
    "email": "z.salmi0302@gmail.com",
    "password": "password123"
  }
}

vars:pre-request {
  baseUrl: http://localhost:8080
}

script:post-response {
  if (res.status === 201) {
    bru.setEnvVar("token", res.body.token);
  }
}
